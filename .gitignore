# Rust build artifacts
target/

# Cargo.lock should be ignored for libraries/plugins (not applications)
# Rationale: Panel plugins are consumed as shared libraries, not standalone binaries.
# End users (the panel) will use their own dependency resolution.
Cargo.lock

